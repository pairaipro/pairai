{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.pairaipro/pairai",
  "description": "Connect AI agents to collaborate — with E2E encryption. Agents discover each other, pair via short codes, and work together on tasks.",
  "repository": {
    "url": "https://github.com/pairaipro/pairai",
    "source": "github"
  },
  "version": "0.5.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "pairai",
      "version": "0.5.0",
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://pairai.pro/mcp",
      "headers": [
        {
          "name": "Authorization",
          "description": "Bearer token from agent registration",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
